# BrainShare backend — copy to .env and fill in. All keys are env-overridable (see app/config.py).
# (The old SIGSHARE keys — GOOGLE_API_KEY/COLLECTION_NAME/EMBEDDING_* — are gone; config is below.)

# ── Relational store ── SQLite for a quick local run; Postgres for real multi-user.
DATABASE_URL=sqlite+aiosqlite:///./data/brainshare.db
# Postgres (run `docker compose up -d postgres`, or point at Supabase / your own PG):
# DATABASE_URL=postgresql+asyncpg://brainshare:brainshare@localhost:5432/brainshare

# ── Vector store (Qdrant) ── embedded path for dev, OR a served URL (docker compose up -d qdrant).
QDRANT_PATH=./data/qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Blob storage (uploaded files) ──
BLOB_DIR=./data/blobs

# ── Modal (GPU inference: text/image/audio/video embedders + whisper) ──
# Token also lives in ~/.modal.toml (profile relikks).
MODAL_APP_NAME=brainshare-embed
# MODAL_PROFILE=relikks
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
EMBED_STUB=false   # true = deterministic offline stub vectors (no Modal) for dev/tests

# ── App ──
CORS_ORIGINS=chrome-extension://*,http://localhost:5173,http://localhost:4700
BRAND_NAME=BrainShare
BRAND_LOGO_PATH=logo.svg
